{
    "type": "SEPARATE",

    "antialiasing": true,

    "noteSize": 0.7,
    "strumSize": 0.7,
    "strumWidth": 160,
    "sustainAlpha": 1,

    "animations":
    {
        "normal":
        [
            {"name": "staticLEFT", "prefix": "staticLeft", "offsets": [0, 0]},
            {"name": "staticDOWN", "prefix": "staticDown", "offsets": [0, 0]},
            {"name": "staticUP", "prefix": "staticUp", "offsets": [0, 0]},
            {"name": "staticRIGHT", "prefix": "staticRight", "offsets": [0, 0]},

            {"name": "pressedLEFT", "prefix": "pressLeft", "offsets": [0, 0]},
            {"name": "pressedDOWN", "prefix": "pressDown", "offsets": [-1, 0]},
            {"name": "pressedUP", "prefix": "pressUp", "offsets": [0, 0]},
            {"name": "pressedRIGHT", "prefix": "pressRight", "offsets": [0, 0]},

            {"name": "confirmLEFT", "prefix": "confirmLeft", "offsets": [0, 0]},
            {"name": "confirmDOWN", "prefix": "confirmDown", "offsets": [0, 0]},
            {"name": "confirmUP", "prefix": "confirmUp", "offsets": [0, 0]},
            {"name": "confirmRIGHT", "prefix": "confirmRight", "offsets": [0, 0]},

            {"name": "arrowLEFT", "prefix": "noteLeft", "offsets": [-2, 0]},
            {"name": "arrowDOWN", "prefix": "noteDown", "offsets": [-2, 0]},
            {"name": "arrowUP", "prefix": "noteUp", "offsets": [-3, 0]},
            {"name": "arrowRIGHT", "prefix": "noteRight", "offsets": [-2, 0]},

            {"name": "holdLEFT", "offsets": [0, 0]},
            {"name": "holdDOWN", "offsets": [-1, 0]},
            {"name": "holdUP", "offsets": [0, 0]},
            {"name": "holdRIGHT", "offsets": [0, 0]}
        ],

        "multikeys":
        [
            {"name": "staticPURPLE", "prefix": "staticLeft"},
            {"name": "pressedPURPLE", "prefix": "pressLeft"},
            {"name": "confirmPURPLE", "prefix": "confirmLeft"},
            {"name": "arrowPURPLE", "prefix": "noteLeft"},
            {"name": "holdPURPLE"},

            {"name": "staticBLUE", "prefix": "staticDown"},
            {"name": "pressedBLUE", "prefix": "pressDown"},
            {"name": "confirmBLUE", "prefix": "confirmDown"},
            {"name": "arrowBLUE", "prefix": "noteDown"},
            {"name": "holdBLUE"},

            {"name": "staticGREEN", "prefix": "staticUp"},
            {"name": "pressedGREEN", "prefix": "pressUp"},
            {"name": "confirmGREEN", "prefix": "confirmUp"},
            {"name": "arrowGREEN", "prefix": "noteUp"},
            {"name": "holdGREEN"},

            {"name": "staticRED", "prefix": "staticRight"},
            {"name": "pressedRED", "prefix": "pressRight"},
            {"name": "confirmRED", "prefix": "confirmRight"},
            {"name": "arrowRED", "prefix": "noteRight"},
            {"name": "holdRED"},

            {"name": "staticWHITE", "prefix": "staticSpace"},
            {"name": "pressedWHITE", "prefix": "pressSpace"},
            {"name": "confirmWHITE", "prefix": "confirmSpace"},
            {"name": "arrowWHITE", "prefix": "noteSpace"},
            {"name": "holdWHITE"},

            {"name": "staticYELLOW", "prefix": "staticLeft"},
            {"name": "pressedYELLOW", "prefix": "pressAltLeft"},
            {"name": "confirmYELLOW", "prefix": "confirmAltLeft"},
            {"name": "arrowYELLOW", "prefix": "noteAltLeft"},
            {"name": "holdYELLOW"},

            {"name": "staticVIOLET", "prefix": "staticDown"},
            {"name": "pressedVIOLET", "prefix": "pressAltDown"},
            {"name": "confirmVIOLET", "prefix": "confirmAltDown"},
            {"name": "arrowVIOLET", "prefix": "noteAltDown"},
            {"name": "holdVIOLET"},

            {"name": "staticDARKRED", "prefix": "staticUp"},
            {"name": "pressedDARKRED", "prefix": "pressAltUp"},
            {"name": "confirmDARKRED", "prefix": "confirmAltUp"},
            {"name": "arrowDARKRED", "prefix": "noteAltUp"},
            {"name": "holdDARKRED"},

            {"name": "staticDARKBLUE", "prefix": "staticRight"},
            {"name": "pressedDARKBLUE", "prefix": "pressAltRight"},
            {"name": "confirmDARKBLUE", "prefix": "confirmAltRight"},
            {"name": "arrowDARKBLUE", "prefix": "noteAltRight"},
            {"name": "holdDARKBLUE"}
        ]
    }
}
